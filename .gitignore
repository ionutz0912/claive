.claive/inbox/
.claive/outbox/
.claive/signals/
.claive/*/

# Auto-generated capabilities manifest (machine-specific)
context/capabilities.md

# Pipeline checkpoints
pipelines/.checkpoint-*

# Personal notes (launch tracking, social assets, ideas)
.notes/

# IDE
.idea/
.vscode/
*.code-workspace

