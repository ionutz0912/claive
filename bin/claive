#!/usr/bin/env bash
set -euo pipefail

# claive — Multi-agent orchestrator for Claude Code
# All agents run in tmux windows within a single session.

CLAIVE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CLAIVE_LIB="$CLAIVE_ROOT/lib"
CLAIVE_HOOKS="$CLAIVE_ROOT/hooks"
CLAIVE_LOCAL_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/claive"

# --- Session name resolution ---
# Priority: positional arg (for start/stop) > --session flag > CLAIVE_SESSION env > "claive"
resolve_session() {
    local name="${1:-${CLAIVE_SESSION:-claive}}"
    echo "$name"
}

# Compute tmux session name: "claive" (default) or "claive-<name>" (named)
tmux_session_name() {
    local session="$1"
    if [ "$session" = "claive" ]; then
        echo "claive"
    else
        echo "claive-$session"
    fi
}

# Parse --session flag from args, return remaining args via CLAIVE_REMAINING_ARGS
_parsed_session=""
parse_session_flag() {
    _parsed_session=""
    CLAIVE_REMAINING_ARGS=()
    while [[ $# -gt 0 ]]; do
        if [ "$1" = "--session" ] && [ $# -gt 1 ]; then
            _parsed_session="$2"; shift 2
        else
            CLAIVE_REMAINING_ARGS+=("$1"); shift
        fi
    done
}

# Default session resolution (used by most commands)
CLAIVE_SESSION_NAME="${CLAIVE_SESSION:-claive}"
export CLAIVE_SESSION="$CLAIVE_SESSION_NAME"
CLAIVE_TMUX="$(tmux_session_name "$CLAIVE_SESSION_NAME")"
CLAIVE_STATE="$CLAIVE_ROOT/state/$CLAIVE_SESSION_NAME"
CLAIVE_MESH="$CLAIVE_ROOT/.claive/$CLAIVE_SESSION_NAME"

mkdir -p "$CLAIVE_STATE" "$CLAIVE_LOCAL_STATE"
chmod 700 "$CLAIVE_LOCAL_STATE"

source "$CLAIVE_LIB/spawn.sh"
source "$CLAIVE_LIB/comms.sh"

usage() {
    cat <<'EOF'
claive — Multi-agent orchestrator for Claude Code

Usage:
  claive spawn <name> [--prompt "..."] [--budget $N] [--branch <b>] [--model opus|sonnet] [--effort low|medium|high|max]
  claive list
  claive read <name> [--lines N]
  claive send <name> "message"
  claive kill <name>
  claive status [<session>]
  claive merge <name>
  claive plan "goal" [--budget $N]
  claive pipeline <file.yaml>
  claive run <pipeline.yaml> [--resume] [--status]
  claive handoff <name>
  claive board [add "desc" | assign <id> <agent> | done <id>]
  claive discover [--print]
  claive start [<session>]
  claive stop [<session>]
  claive monitor [<session>]
  claive help

Multi-session:
  claive start              # default session "claive"
  claive start myproject    # named session "claive-myproject"
  claive stop myproject     # stop only that session
  claive status             # list all active claive sessions
  claive status myproject   # detailed view for one session

Orchestrator prompting examples (after 'claive start'):

  Freeform goal (reads PLAN.md, decomposes into agents, asks before spawning):
    "Build the project at ~/projects/my-app/"

  Goal with hints (you sketch the parallelism):
    "Build the app. Setup first, then backend and frontend in parallel,
     then integration tests, and finally the dashboard."

  Pipeline YAML (exact task definitions):
    "Run the pipeline at pipelines/my-pipeline.yaml"

  Single task (one agent, no plan):
    "Spawn an agent to add JWT authentication to the API"

Options:
  --prompt    Initial prompt for the agent
  --budget    Budget cap in dollars (e.g., 5.00)
  --branch    Git branch for agent isolation
  --model     Model: opus or sonnet (default: sonnet for agents, opus for orchestrator)
  --effort    Effort level: low, medium, high, max
  --lines     Number of terminal lines to capture (default: 50)
  --session   Target a specific session (alternative to positional arg)
EOF
}

ensure_session() {
    if ! tmux has-session -t "$CLAIVE_TMUX" 2>/dev/null; then
        echo "No claive session found. Creating one..."
        tmux new-session -d -s "$CLAIVE_TMUX" -n orchestrator
        echo "Session '$CLAIVE_TMUX' created. Window 'orchestrator' is ready."
    fi
}

do_status_all() {
    echo "=== claive sessions ==="
    echo ""
    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -E '^claive(-|$)' || true)
    if [ -z "$sessions" ]; then
        echo "No active claive sessions."
        return
    fi
    while IFS= read -r sess; do
        local count
        count=$(tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null | wc -l | tr -d ' ')
        echo "  $sess ($count agents)"
    done <<< "$sessions"
}

do_status_one() {
    echo "=== claive status ($CLAIVE_TMUX) ==="
    echo ""

    if ! tmux has-session -t "$CLAIVE_TMUX" 2>/dev/null; then
        echo "Session: not running"
        return
    fi

    local agents count
    agents=$(tmux list-windows -t "$CLAIVE_TMUX" -F '#{window_name}')
    count=$(echo "$agents" | wc -l | tr -d ' ')
    echo "Session: $CLAIVE_TMUX (active)     $count agents"
    echo ""
    printf "  %-18s %-12s %s\n" "NAME" "HEARTBEAT" "BUDGET"

    while IFS= read -r name; do
        local hb budget_row
        hb=$(python3 "$CLAIVE_LIB/heartbeat.py" status "$name" 2>/dev/null || echo "-")
        budget_row=$(python3 "$CLAIVE_LIB/budget.py" row "$name" 2>/dev/null || echo "-")
        printf "  %-18s %-12s %s\n" "$name" "$hb" "$budget_row"
    done <<< "$agents"

    python3 "$CLAIVE_LIB/dag.py" checkpoint-summary 2>/dev/null
    echo ""
    local audit_file="$CLAIVE_ROOT/state/audit.jsonl"
    local audit_count
    audit_count=$(wc -l < "$audit_file" 2>/dev/null || echo 0)
    echo "Audit: ${audit_count// /} entries"
}

case "${1:-help}" in
    spawn)
        shift
        parse_session_flag "$@"; set -- "${CLAIVE_REMAINING_ARGS[@]}"
        if [ -n "$_parsed_session" ]; then
            CLAIVE_SESSION_NAME="$_parsed_session"
            export CLAIVE_SESSION="$CLAIVE_SESSION_NAME"
            CLAIVE_TMUX="$(tmux_session_name "$CLAIVE_SESSION_NAME")"
            CLAIVE_STATE="$CLAIVE_ROOT/state/$CLAIVE_SESSION_NAME"
            CLAIVE_MESH="$CLAIVE_ROOT/.claive/$CLAIVE_SESSION_NAME"
            mkdir -p "$CLAIVE_STATE"
        fi
        ensure_session
        do_spawn "$@"
        ;;
    list)
        ensure_session
        tmux list-windows -t "$CLAIVE_TMUX" -F '#{window_name}' 2>/dev/null
        ;;
    read)
        shift
        ensure_session
        do_read "$@"
        ;;
    send)
        shift
        ensure_session
        do_send "$@"
        ;;
    kill)
        shift
        ensure_session
        do_kill "$@"
        ;;
    status)
        shift
        if [ $# -eq 0 ]; then
            do_status_all
        else
            CLAIVE_SESSION_NAME="$1"
            export CLAIVE_SESSION="$CLAIVE_SESSION_NAME"
            CLAIVE_TMUX="$(tmux_session_name "$CLAIVE_SESSION_NAME")"
            CLAIVE_STATE="$CLAIVE_ROOT/state/$CLAIVE_SESSION_NAME"
            CLAIVE_MESH="$CLAIVE_ROOT/.claive/$CLAIVE_SESSION_NAME"
            do_status_one
        fi
        ;;
    merge)
        shift
        do_merge "$@"
        ;;
    plan)
        shift
        python3 "$CLAIVE_LIB/dag.py" plan "$@"
        ;;
    run)
        shift
        python3 "$CLAIVE_LIB/dag.py" run "$@"
        ;;
    pipeline)
        shift
        python3 "$CLAIVE_LIB/dag.py" pipeline "$@"
        ;;
    handoff)
        shift
        ensure_session
        python3 "$CLAIVE_LIB/handoff.py" "$@"
        ;;
    board)
        shift
        python3 "$CLAIVE_LIB/dag.py" board "$@"
        ;;
    stop)
        shift
        if [ $# -gt 0 ]; then
            CLAIVE_SESSION_NAME="$1"
            export CLAIVE_SESSION="$CLAIVE_SESSION_NAME"
            CLAIVE_TMUX="$(tmux_session_name "$CLAIVE_SESSION_NAME")"
            CLAIVE_STATE="$CLAIVE_ROOT/state/$CLAIVE_SESSION_NAME"
            CLAIVE_MESH="$CLAIVE_ROOT/.claive/$CLAIVE_SESSION_NAME"
        fi
        if ! tmux has-session -t "$CLAIVE_TMUX" 2>/dev/null; then
            echo "No claive session '$CLAIVE_TMUX' running."
        else
            agent_count=$(tmux list-windows -t "$CLAIVE_TMUX" -F '#{window_name}' 2>/dev/null | wc -l | tr -d ' ')
            tmux kill-session -t "$CLAIVE_TMUX"
            echo "Killed session '$CLAIVE_TMUX' ($agent_count agents)."
        fi
        # Clean up runtime state
        rm -rf "$CLAIVE_MESH/signals"/* "$CLAIVE_MESH/inbox"/* "$CLAIVE_MESH/outbox"/* 2>/dev/null || true
        rm -f "$CLAIVE_ROOT"/pipelines/.checkpoint-*.json 2>/dev/null || true
        echo "Cleaned up signals and checkpoints. Ready for fresh start."
        ;;
    start)
        shift
        if [ $# -gt 0 ]; then
            CLAIVE_SESSION_NAME="$1"
            export CLAIVE_SESSION="$CLAIVE_SESSION_NAME"
            CLAIVE_TMUX="$(tmux_session_name "$CLAIVE_SESSION_NAME")"
            CLAIVE_STATE="$CLAIVE_ROOT/state/$CLAIVE_SESSION_NAME"
            CLAIVE_MESH="$CLAIVE_ROOT/.claive/$CLAIVE_SESSION_NAME"
        fi
        mkdir -p "$CLAIVE_STATE"
        # If session exists, stop it first for a clean start
        if tmux has-session -t "$CLAIVE_TMUX" 2>/dev/null; then
            agent_count=$(tmux list-windows -t "$CLAIVE_TMUX" -F '#{window_name}' 2>/dev/null | wc -l | tr -d ' ')
            echo "Existing session found ($agent_count agents). Stopping it..."
            tmux kill-session -t "$CLAIVE_TMUX"
            rm -rf "$CLAIVE_MESH/signals"/* "$CLAIVE_MESH/inbox"/* "$CLAIVE_MESH/outbox"/* 2>/dev/null || true
            rm -f "$CLAIVE_ROOT"/pipelines/.checkpoint-*.json 2>/dev/null || true
        fi
        # Discover capabilities before launching orchestrator
        python3 "$CLAIVE_LIB/discover.py" 2>/dev/null || true
        tmux new-session -d -s "$CLAIVE_TMUX" -n orchestrator
        # Enable mouse scrolling and increase scrollback for all claive windows
        tmux set-option -t "$CLAIVE_TMUX" mouse on
        tmux set-option -t "$CLAIVE_TMUX" history-limit 50000
        tmux send-keys -t "$CLAIVE_TMUX:orchestrator" "CLAIVE_SESSION=$CLAIVE_SESSION_NAME claude --dangerously-skip-permissions --model opus --effort low --append-system-prompt \"\$(cat $CLAIVE_ROOT/SKILL.md)\"" Enter
        if [ -n "${TMUX:-}" ]; then
            tmux select-window -t "$CLAIVE_TMUX:orchestrator"
        else
            tmux attach -t "$CLAIVE_TMUX:orchestrator"
        fi
        ;;
    discover)
        python3 "$CLAIVE_LIB/discover.py" "${@:2}"
        ;;
    monitor)
        shift
        if [ $# -gt 0 ]; then
            exec watch -n 5 "claive status $1"
        else
            exec watch -n 5 claive status
        fi
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $1"
        usage
        exit 1
        ;;
esac
